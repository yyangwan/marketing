{
  "name": "marketing",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "node node_modules/vitest/vitest.mjs run",
    "test:run": "node node_modules/vitest/vitest.mjs run",
    "test:ui": "node node_modules/vitest/vitest.mjs --ui",
    "test:watch": "node node_modules/vitest/vitest.mjs",
    "test:coverage": "vitest --coverage",
    "db:setup": "prisma generate && prisma db push",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tiptap/extension-character-count": "^3.22.4",
    "@tiptap/extension-placeholder": "^3.22.4",
    "@tiptap/pm": "^3.22.4",
    "@tiptap/react": "^3.22.4",
    "@tiptap/starter-kit": "^3.22.4",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.9.0",
    "next": "16.2.4",
    "next-auth": "^5.0.0-beta.31",
    "prisma": "^7.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.4.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.2.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.4.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "happy-dom": "^20.9.0",
    "jsdom": "^29.0.2",
    "next-router-mock": "^1.0.5",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.0.9"
  },
  "vitest": {
    "environment": "jsdom",
    "environmentOptions": {
      "url": "http://localhost:3000"
    },
    "setupFiles": [
      "./vitest.setup.ts"
    ]
  }
