generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())

  memberships  WorkspaceMember[]
  notifications Notification[]
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  members       WorkspaceMember[]
  projects      Project[]
  invites       WorkspaceInvite[]
  brandVoices   BrandVoice[]
  aiTemplates   AITemplate[]
  notifications Notification[]
}

model WorkspaceMember {
  id          String   @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String
  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        String   @default("member")
  joinedAt    DateTime @default(now())

  @@unique([workspaceId, userId])
}

model WorkspaceInvite {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  token       String    @unique @default(cuid())
  email       String
  role        String    @default("member")
  invitedBy   String
  usedAt      DateTime?
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
}

model Project {
  id                String   @id @default(cuid())
  name              String
  clientName        String   @default("")
  workspaceId       String
  workspace         Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  brandVoiceId      String?   // Default brand voice for this project
  brandVoice        BrandVoice? @relation("ProjectBrandVoice", fields: [brandVoiceId], references: [id], onDelete: Restrict)
  defaultAssigneeId String?   // Default assignee for content in this project
  createdAt         DateTime @default(now())

  contentPieces ContentPiece[]

  @@unique([workspaceId, name])
}

model ContentPiece {
  id               String            @id @default(cuid())
  projectId        String
  project          Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title            String
  type             String            @default("blog_post")
  brief            String
  brandVoiceId     String?           // Brand voice used for this content
  brandVoice       BrandVoice?       @relation("ContentPieceBrandVoice", fields: [brandVoiceId], references: [id], onDelete: Restrict)
  status           String            @default("draft")
  reviewToken      String?           @unique @map("ContentPiece_reviewToken_key")
  reviewExpiresAt  DateTime?
  platformContents PlatformContent[]
  reviewComments   ReviewComment[]
  quality          ContentQuality?   // AI evaluation scores
  schedules        ContentSchedule[] // Phase 1D: Scheduling records
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model PlatformContent {
  id              String       @id @default(cuid())
  contentPieceId  String
  contentPiece    ContentPiece @relation(fields: [contentPieceId], references: [id], onDelete: Cascade)
  platform        String
  status          String       @default("draft")
  content         String?
  publishedUrl    String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([contentPieceId, platform])
}

model ReviewComment {
  id             String       @id @default(cuid())
  contentPieceId String
  contentPiece   ContentPiece @relation(fields: [contentPieceId], references: [id], onDelete: Cascade)
  authorName     String
  comment        String?
  action         String
  createdAt      DateTime     @default(now())
}

// Phase 1C: Brand Voice System
model BrandVoice {
  id          String    @id @default(cuid())
  name        String
  workspaceId String
  workspace   Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  description String?   @default("")
  guidelines  String?   @default("")  // Dos and don'ts for tone
  samples     String    // JSON array of sample content strings
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations: can be used as default for projects or selected for content pieces
  projects       Project[]        @relation("ProjectBrandVoice")
  contentPieces  ContentPiece[]   @relation("ContentPieceBrandVoice")
}

// Phase 1C: Custom AI Templates
model AITemplate {
  id          String    @id @default(cuid())
  name        String
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  description String?   @default("")
  template    String    // Template content with {variable} placeholders
  variables   String    // JSON array: [{name, type, description, required}]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// Phase 1C: Content Quality Metrics
model ContentQuality {
  id               String   @id @default(cuid())
  contentPieceId   String   @unique @map("ContentQuality_contentPieceId_key")
  contentPiece     ContentPiece @relation(fields: [contentPieceId], references: [id], onDelete: Cascade)

  // AI scores (0-10)
  quality      Int      @default(0)      // Overall writing quality
  engagement   Int      @default(0)      // How engaging it is
  brandVoice   Int      @default(0)      // How well it matches brand voice
  platformFit  Int      @default(0)      // How well it fits the platform

  // AI suggestions for improvement
  suggestions  String?  // JSON array of improvement suggestions

  // Evaluation metadata
  evaluatedAt  DateTime @default(now())
}

// Phase 1D: Scheduling
model ContentSchedule {
  id          String   @id @default(cuid())
  contentId   String
  contentPiece ContentPiece @relation(fields: [contentId], references: [id], onDelete: Cascade)
  scheduledAt DateTime
  publishedAt DateTime?
  // Status values must match ScheduleStatus type in src/types/index.ts
  // Valid values: "scheduled" | "publishing" | "published" | "failed"
  // Note: SQLite CHECK constraint should be added via migration for production:
  // ALTER TABLE ContentSchedule ADD COLUMN status TEXT CHECK(status IN ('scheduled', 'publishing', 'published', 'failed'));
  status      String   @default("scheduled")
  createdAt   DateTime @default(now())

  @@unique([contentId])
  @@index([scheduledAt])
  @@index([status])
}

// Phase 1D: Notifications
model Notification {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  type        String   // "content_review" | "content_approved" | "content_published" | "schedule_reminder" | "mention"
  title       String
  message     String
  link        String?  // URL to relevant content
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@index([workspaceId])
}
