generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())

  memberships  WorkspaceMember[]
  notifications Notification[]
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  members           WorkspaceMember[]
  projects          Project[]
  invites           WorkspaceInvite[]
  brandVoices       BrandVoice[]
  aiTemplates       AITemplate[]
  notifications     Notification[]
  genieSources      GenieSource[]
  platformApiConfigs PlatformApiConfig[]
}

model WorkspaceMember {
  id          String   @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String
  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        String   @default("member")
  joinedAt    DateTime @default(now())

  @@unique([workspaceId, userId])
}

model WorkspaceInvite {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  token       String    @unique @default(cuid())
  email       String
  role        String    @default("member")
  invitedBy   String
  usedAt      DateTime?
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
}

model Project {
  id                String   @id @default(cuid())
  name              String
  clientName        String   @default("")
  workspaceId       String
  workspace         Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  brandVoiceId      String?   // Default brand voice for this project
  brandVoice        BrandVoice? @relation("ProjectBrandVoice", fields: [brandVoiceId], references: [id], onDelete: Restrict)
  defaultAssigneeId String?   // Default assignee for content in this project
  createdAt         DateTime @default(now())

  contentPieces ContentPiece[]

  @@unique([workspaceId, name])
}

model ContentPiece {
  id               String            @id @default(cuid())
  projectId        String
  project          Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title            String
  type             String            @default("blog_post")
  brief            String
  brandVoiceId     String?           // Brand voice used for this content
  brandVoice       BrandVoice?       @relation("ContentPieceBrandVoice", fields: [brandVoiceId], references: [id], onDelete: Restrict)
  status           String            @default("draft")
  reviewToken      String?           @unique @map("ContentPiece_reviewToken_key")
  reviewExpiresAt  DateTime?
  platformContents PlatformContent[]
  reviewComments   ReviewComment[]
  quality          ContentQuality?   // AI evaluation scores
  qualityHistory   QualityHistory[]  // Historical evaluation records
  schedules        ContentSchedule[] // Phase 1D: Scheduling records
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model PlatformContent {
  id              String       @id @default(cuid())
  contentPieceId  String
  contentPiece    ContentPiece @relation(fields: [contentPieceId], references: [id], onDelete: Cascade)
  platform        String
  status          String       @default("draft")
  content         String?
  publishedUrl    String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([contentPieceId, platform])
}

model ReviewComment {
  id             String       @id @default(cuid())
  contentPieceId String
  contentPiece   ContentPiece @relation(fields: [contentPieceId], references: [id], onDelete: Cascade)
  authorName     String
  comment        String?
  action         String
  createdAt      DateTime     @default(now())
}

// Phase 1C: Brand Voice System
model BrandVoice {
  id          String    @id @default(cuid())
  name        String
  workspaceId String
  workspace   Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  description String?   @default("")
  guidelines  String?   @default("")  // Dos and don'ts for tone
  samples     String    // JSON array of sample content strings
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations: can be used as default for projects or selected for content pieces
  projects       Project[]        @relation("ProjectBrandVoice")
  contentPieces  ContentPiece[]   @relation("ContentPieceBrandVoice")
}

// Phase 1C: Custom AI Templates
model AITemplate {
  id          String    @id @default(cuid())
  name        String
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  description String?   @default("")
  template    String    // Template content with {variable} placeholders
  variables   String    // JSON array: [{name, type, description, required}]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// Phase 1C: Content Quality Metrics
model ContentQuality {
  id               String   @id @default(cuid())
  contentPieceId   String   @unique @map("ContentQuality_contentPieceId_key")
  contentPiece     ContentPiece @relation(fields: [contentPieceId], references: [id], onDelete: Cascade)

  // AI scores (0-10)
  quality      Int      @default(0)      // Overall writing quality
  engagement   Int      @default(0)      // How engaging it is
  brandVoice   Int      @default(0)      // How well it matches brand voice
  platformFit  Int      @default(0)      // How well it fits the platform

  // Extended AI scores (0-10)
  sentiment        Int      @default(0)   // Sentiment analysis (-10 to 10 converted to 0-10)
  topicConsistency Int      @default(0)   // Topic consistency score
  originality      Int      @default(0)   // Originality score

  // Local metrics (computed instantly)
  localMetrics     String?  // JSON: {readabilityScore, vocabularyDiversity, sentenceComplexity, consistencyScore}

  // AI suggestions for improvement
  suggestions  String?  // JSON array of improvement suggestions

  // Historical tracking
  previousScores   String?  // JSON: store previous evaluation for comparison
  evaluationCount  Int      @default(1)   // Track how many times evaluated

  // Evaluation metadata
  evaluatedAt  DateTime @default(now())

  @@index([evaluatedAt])
}

// Phase 1C+: Quality History (tracks evaluation changes over time)
model QualityHistory {
  id               String   @id @default(cuid())
  contentPieceId   String
  contentPiece     ContentPiece @relation(fields: [contentPieceId], references: [id], onDelete: Cascade)

  // AI scores snapshot
  quality          Int
  engagement       Int
  brandVoice       Int
  platformFit      Int
  sentiment        Int      @default(0)
  topicConsistency Int      @default(0)
  originality      Int      @default(0)

  // Content hash to detect actual changes
  contentHash      String

  evaluatedAt      DateTime @default(now())

  @@index([contentPieceId, evaluatedAt])
}

// Phase 1D: Scheduling
model ContentSchedule {
  id          String   @id @default(cuid())
  contentId   String
  contentPiece ContentPiece @relation(fields: [contentId], references: [id], onDelete: Cascade)
  scheduledAt DateTime
  publishedAt DateTime?
  // Status values must match ScheduleStatus type in src/types/index.ts
  // Valid values: "scheduled" | "publishing" | "published" | "failed"
  // Note: SQLite CHECK constraint should be added via migration for production:
  // ALTER TABLE ContentSchedule ADD COLUMN status TEXT CHECK(status IN ('scheduled', 'publishing', 'published', 'failed'));
  status      String   @default("scheduled")
  createdAt   DateTime @default(now())

  @@unique([contentId])
  @@index([scheduledAt])
  @@index([status])
}

// Phase 1D: Notifications
model Notification {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  type        String   // "content_review" | "content_approved" | "content_published" | "schedule_reminder" | "mention"
  title       String
  message     String
  link        String?  // URL to relevant content
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@index([workspaceId])
}

// Phase 1E: Genie Auto-Content Factory - URL Sources
model GenieSource {
  id               String   @id @default(cuid())
  workspaceId       String
  workspace         Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  url               String   @unique

  // Extracted metadata from URL analysis
  businessType      String?  // "电商", "SaaS", "本地服务", "内容创作"
  keyProducts       String?  // JSON array: ["产品A", "产品B"]
  brandTone         String?  // "专业", "亲切", "幽默", "高端"
  targetAudience    String?  // "Z世代", "职场人士", "宝妈", etc.
  recurringTopics   String?  // JSON array: ["话题1", "话题2"]

  // Analysis tracking
  lastAnalyzedAt    DateTime?
  enabled           Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([workspaceId, enabled])
  @@index([lastAnalyzedAt])
}

// Phase 1F: Platform API Configuration
model PlatformApiConfig {
  id          String   @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  platform    String   // "wechat" | "weibo" | "xiaohongshu" | "douyin"

  // Platform-specific credentials (stored encrypted in production)
  appId      String?  @map("app_id")       // WeChat AppID, Weibo App Key, etc.
  appSecret  String?  @map("app_secret")   // WeChat AppSecret, Weibo App Secret, etc.
  accessToken String? @map("access_token") // OAuth access token
  refreshTokn String?  @map("refresh_token") // OAuth refresh token

  // Token management
  tokenExpiresAt DateTime? // When access token expires
  lastRefreshedAt DateTime? // When we last refreshed the token

  // Additional platform-specific config (JSON)
  extraConfig String? // Platform-specific settings

  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([workspaceId, platform])
  @@index([workspaceId, enabled])
}

// Phase 1F: Publish History
model PublishHistory {
  id              String   @id @default(cuid())
  workspaceId     String
  platform        String   // "wechat" | "weibo" | "xiaohongshu" | "douyin"
  platformContentId String  // References PlatformContent.id

  // Content data
  title           String
  content         String   // The published content

  // Result
  status          String   // "success" | "failed" | "pending"
  publishedUrl    String?  // URL of published content
  platformPostId  String?  @map("platform_post_id") // ID returned by platform
  errorMessage    String?  @map("error_message") // Error message if failed

  // Retry tracking
  attemptCount    Int      @default(0)
  lastAttemptAt   DateTime @default(now())
  completedAt     DateTime?

  createdAt       DateTime @default(now())

  @@index([workspaceId, platform])
  @@index([platformContentId])
  @@index([status])
  @@index([createdAt])
}
