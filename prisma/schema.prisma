generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model ContentPiece {
  id               String            @id @default(cuid())
  workspaceId      String
  projectId        String
  brandId          String?
  createdByUserId  String
  title            String
  type             String            @default("blog_post")
  brief            String            @db.MediumText
  brandVoiceId     String?
  brandVoice       BrandVoice?       @relation("ContentPieceBrandVoice", fields: [brandVoiceId], references: [id], onDelete: Restrict)
  status           String            @default("draft")
  reviewToken      String?           @unique
  reviewExpiresAt  DateTime?
  platformContents PlatformContent[]
  reviewComments   ReviewComment[]
  quality          ContentQuality?
  qualityHistory   QualityHistory[]
  schedules        ContentSchedule[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([workspaceId])
  @@index([projectId])
  @@index([brandId])
  @@index([createdByUserId])
}

model PlatformContent {
  id             String       @id @default(cuid())
  contentPieceId String
  contentPiece   ContentPiece @relation(fields: [contentPieceId], references: [id], onDelete: Cascade)
  platform       String
  status         String       @default("draft")
  content        String?      @db.MediumText
  publishedUrl   String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([contentPieceId, platform])
}

model ReviewComment {
  id             String       @id @default(cuid())
  contentPieceId String
  contentPiece   ContentPiece @relation(fields: [contentPieceId], references: [id], onDelete: Cascade)
  authorName     String
  comment        String?      @db.MediumText
  action         String
  createdAt      DateTime     @default(now())
}

// Business generation profile linked to a Brand ID owned by 智链.
model BrandVoice {
  id              String         @id @default(cuid())
  workspaceId     String
  brandId         String?
  name            String
  description     String?        @db.Text
  guidelines      String?        @db.Text
  samples         String         @db.MediumText
  createdByUserId String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  contentPieces   ContentPiece[] @relation("ContentPieceBrandVoice")

  @@index([workspaceId])
  @@index([brandId])
}

model AITemplate {
  id          String   @id @default(cuid())
  name        String
  workspaceId String
  description String?  @db.Text
  template    String   @db.MediumText
  variables   String   @db.MediumText
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([workspaceId])
}

model ContentQuality {
  id               String       @id @default(cuid())
  contentPieceId   String       @unique
  contentPiece     ContentPiece @relation(fields: [contentPieceId], references: [id], onDelete: Cascade)
  quality          Int          @default(0)
  engagement       Int          @default(0)
  brandVoice       Int          @default(0)
  platformFit      Int          @default(0)
  sentiment        Int          @default(0)
  topicConsistency Int          @default(0)
  originality      Int          @default(0)
  localMetrics     String?      @db.MediumText
  suggestions      String?      @db.MediumText
  previousScores   String?      @db.MediumText
  evaluationCount  Int          @default(1)
  evaluatedAt      DateTime     @default(now())

  @@index([evaluatedAt])
}

model QualityHistory {
  id               String       @id @default(cuid())
  contentPieceId   String
  contentPiece     ContentPiece @relation(fields: [contentPieceId], references: [id], onDelete: Cascade)
  quality          Int
  engagement       Int
  brandVoice       Int
  platformFit      Int
  sentiment        Int          @default(0)
  topicConsistency Int          @default(0)
  originality      Int          @default(0)
  contentHash      String
  evaluatedAt      DateTime     @default(now())

  @@index([contentPieceId, evaluatedAt])
}

model ContentSchedule {
  id           String       @id @default(cuid())
  contentId    String
  contentPiece ContentPiece @relation(fields: [contentId], references: [id], onDelete: Cascade)
  scheduledAt  DateTime
  publishedAt  DateTime?
  status       String       @default("scheduled")
  createdAt    DateTime     @default(now())

  @@unique([contentId])
  @@index([scheduledAt])
  @@index([status])
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  workspaceId String
  type        String
  title       String
  message     String   @db.MediumText
  link        String?
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@index([workspaceId])
}

model GenieSource {
  id              String   @id @default(cuid())
  workspaceId     String
  url             String
  businessType    String?
  keyProducts     String?  @db.MediumText
  brandTone       String?
  targetAudience  String?
  recurringTopics String?  @db.MediumText
  lastAnalyzedAt  DateTime?
  enabled         Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([workspaceId, enabled])
  @@unique([workspaceId, url])
  @@index([lastAnalyzedAt])
}

model PlatformApiConfig {
  id             String   @id @default(cuid())
  workspaceId    String
  platform       String
  appId          String?  @map("app_id")
  appSecret      String?  @map("app_secret")
  accessToken    String?  @map("access_token")
  refreshTokn    String?  @map("refresh_token")
  tokenExpiresAt DateTime?
  lastRefreshedAt DateTime?
  extraConfig    String?  @db.MediumText
  enabled        Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([workspaceId, platform])
  @@index([workspaceId, enabled])
}

model PublishHistory {
  id                String   @id @default(cuid())
  workspaceId       String
  platform          String
  platformContentId String
  title             String
  content           String   @db.MediumText
  status            String
  publishedUrl      String?
  platformPostId    String?  @map("platform_post_id")
  errorMessage      String?  @map("error_message") @db.Text
  attemptCount      Int      @default(0)
  lastAttemptAt     DateTime @default(now())
  completedAt       DateTime?
  createdAt         DateTime @default(now())

  @@index([workspaceId, platform])
  @@index([platformContentId])
  @@index([status])
  @@index([createdAt])
}
